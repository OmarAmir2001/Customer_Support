# This file contains environment variables for the Customer Support Agent With Escalation application.
APP_NAME="Customer Support Agent With Escalation"
APP_VERSION="0.1.0"
# Add any other environment variables you need for your application here. For example:
# DATABASE_URL="your_database_url_here"
# API_KEY="your_api_key_here"
GROQ_API_KEY="your_groq_api_key_here"

# File Allowed Types and Size limits for file upload
File_Allowed_Types=["text/plain", "application/pdf","text/markdown"]
File_Max_Size=10485760  # 10 MB in bytes
File_Default_CHUNK_SIZE=512000  # 500 KB in bytes

MONGODB_URL="mongodb://localhost:27017"
MONGODB_DATABASE="Customer-Support"